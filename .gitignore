# ── Secrets ──────────────────────────────────────────────────────────────────
# Never commit Snowflake credentials or any environment secrets.
.env

# ── Data ──────────────────────────────────────────────────────────────────────
# Raw parquet cache is READ-ONLY and too large for git (source of truth = Snowflake).
# Processed outputs are generated artefacts — always reproducible from the notebook.
data/raw/
data/processed/
*.parquet
*.csv

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# ── Virtual Environment ───────────────────────────────────────────────────────
# The venv is managed by uv and is always re-created via `uv sync`.
.venv/

# ── uv & Python version ───────────────────────────────────────────────────────
# IMPORTANT: uv.lock and .python-version MUST be committed.
# uv.lock guarantees 100% Dev/Prod reproducibility.
# .python-version pins the exact Python version for every contributor.
# (These are intentionally NOT listed here.)

# ── Ruff cache ────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
# Checkpoint files are local editor state, not source code.
# Notebook outputs are stripped by the nbstripout pre-commit hook before commit.
.ipynb_checkpoints/

# ── Pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/

# ── Visuals ───────────────────────────────────────────────────────────────────
# PNGs/SVGs are generated by the notebook. Tracked for portfolio / PR review.
# Uncomment below to exclude them instead.
# visuals/
